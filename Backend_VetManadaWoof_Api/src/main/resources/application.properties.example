# ============================================
# Configuración general de la aplicación
# ============================================

# Nombre de la aplicación
spring.application.name=VetManadaWoof

# Puerto en el que correrá la app
server.port=8088

# Contexto base para los endpoints
server.servlet.context-path=/

# ============================================
# Configuración de la base de datos MySQL
# cada desarrollador debe copiarlo a:
# src/main/resources/application.properties
# y reemplazar con sus credenciales locales.
# ============================================

# URL de conexión
spring.datasource.url=jdbc:mysql://localhost:3306/vet_manada_woof

# Usuario de la base de datos
spring.datasource.username=TU_USUARIO

# Contraseña de la base de datos
spring.datasource.password=TU_PASSWORD

# Driver JDBC para MySQL (no cambiar)
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ============================================
# Configuración de JPA / Hibernate
# ============================================

# Define cómo sincroniza las entidades con la BD:
# - update: crea/modifica tablas sin borrar datos (desarrollo)
# - validate: solo valida, no cambia la BD
# - none: no hace nada (producción)
spring.jpa.hibernate.ddl-auto=validate

# Dialecto específico de MySQL (para generar SQL optimizado)
spring.jpa.database-platform=org.hibernate.dialect.MySQL8Dialect

# Mostrar las consultas SQL generadas (solo para desarrollo)
spring.jpa.show-sql=true

# Formatear las consultas SQL en consola para mayor legibilidad
spring.jpa.properties.hibernate.format_sql=true
